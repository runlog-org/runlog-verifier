# {{SETUP}}
# --- action ---
# {{ACTION_OPEN}}# {{ACTION_BODY}}# {{ACTION_CLOSE}}# --- capture ---
try:
    _v_RESULT
except NameError:
    sys.stdout.write(json.dumps({"raised": True, "exception": "NameError", "message": "$RESULT was never bound by the action"}))
    sys.exit(0)
try:
    json.dumps(_v_RESULT)
